    "music-metadata": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.0.0",
    "happy-dom": "^20.10.6",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
