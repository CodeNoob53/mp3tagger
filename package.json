{
  "name": "mp3tagger",
  "private": true,
  "version": "1.0.0",
  "description": "Browser-based MP3/WAV metadata editor and audio converter. All processing happens locally.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
